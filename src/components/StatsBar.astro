---
import { CLAN } from "../data/clan";
import { members } from "../data/members";
---

<section id="stats" class="relative border-y border-border bg-card/50 py-10 md:py-12 mt-16 md:mt-24">
  <div class="mx-auto max-w-[1280px] px-4 md:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-6 md:flex md:justify-center md:gap-16 lg:gap-20">
      <!-- Members -->
      <div class="flex flex-col items-center text-center">
        <svg class="h-5 w-5 text-muted-foreground mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>
        </svg>
        <span class="font-display text-4xl md:text-5xl text-primary leading-none">{members.length}</span>
        <span class="font-condensed text-[10px] md:text-[11px] uppercase tracking-[0.2em] text-muted-foreground mt-2">Members</span>
      </div>

      <!-- Total Match -->
      <div class="flex flex-col items-center text-center">
        <svg class="h-5 w-5 text-muted-foreground mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14.5 17.5 3 6V3h3l11.5 11.5"/><path d="M13 19l6-6"/><path d="m16 16 3.5 3.5"/><path d="M19 21.5 21.5 19"/>
        </svg>
        <span class="font-display text-4xl md:text-5xl text-primary leading-none">{CLAN.stats.totalMatch.toLocaleString()}+</span>
        <span class="font-condensed text-[10px] md:text-[11px] uppercase tracking-[0.2em] text-muted-foreground mt-2">Total Match</span>
      </div>

      <!-- Win Rate -->
      <div class="flex flex-col items-center text-center">
        <svg class="h-5 w-5 text-muted-foreground mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>
        </svg>
        <span class="font-display text-4xl md:text-5xl text-primary leading-none">{CLAN.stats.winRate}%</span>
        <span class="font-condensed text-[10px] md:text-[11px] uppercase tracking-[0.2em] text-muted-foreground mt-2">Win Rate</span>
      </div>

      <!-- Established -->
      <div class="flex flex-col items-center text-center">
        <svg class="h-5 w-5 text-muted-foreground mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/>
        </svg>
        <span class="font-display text-4xl md:text-5xl text-primary leading-none">{CLAN.established}</span>
        <span class="font-condensed text-[10px] md:text-[11px] uppercase tracking-[0.2em] text-muted-foreground mt-2">Established</span>
      </div>
    </div>
  </div>
</section>
