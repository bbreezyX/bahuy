---
import { CLAN } from "../data/clan";
import { members } from "../data/members";
import HeroCards from "./HeroCards";

const featuredMembers = members.filter((m) => m.isFeatured).slice(0, 5);
---

<section
  id="hero"
  class="relative overflow-x-clip min-h-svh flex flex-col items-center justify-center pt-16 pb-2 md:pt-24 md:pb-8"
>
  <div
    class="relative w-full max-w-[1280px] px-4 md:px-6 lg:px-8 flex flex-col items-center flex-1 justify-center md:justify-between gap-6 md:gap-0"
  >
    <div
      class="w-full flex flex-col items-center md:flex-1 md:justify-center mt-0 md:mt-6"
    >
      <!-- Mobile hero character -->
      <div class="sm:hidden flex justify-center mb-[-2rem]">
        <div class="hero-char-mobile-wrapper">
          <img
            src="/cha3.png"
            alt=""
            draggable="false"
            class="hero-char-mobile"
          />
        </div>
      </div>

      <!-- Clan Name -->
      <div
        class="flex flex-col items-center mb-6 md:mb-10 w-full animate-slide-up"
      >
        {/* Subtitle tag above name */}
        <div class="hero-subtitle mb-4 md:mb-5">
          <span
            class="font-condensed text-[10px] sm:text-xs uppercase tracking-[0.35em] text-primary/70 font-semibold"
          >
            {CLAN.subtitle}
          </span>
        </div>

        <h1
          class="hero-title relative text-center leading-[0.8] text-white uppercase select-none"
        >
          <span
            class="block font-display text-[5rem] sm:text-[7.5rem] md:text-[9rem] lg:text-[11.5rem] xl:text-[14rem] tracking-tighter"
          >
            BAHUY.
          </span>
          <span
            class="block font-display text-[2.5rem] sm:text-[3.5rem] md:text-[4.5rem] lg:text-[5.5rem] xl:text-[6.5rem] tracking-[0.2em] text-white -mt-2 md:-mt-4"
          >
            N FRIENDS
          </span>
        </h1>

        {/* Motto */}
        <p
          class="hero-motto mt-5 md:mt-7 font-condensed text-sm sm:text-base md:text-lg uppercase tracking-[0.3em] text-white/30"
        >
          {CLAN.motto}
        </p>
      </div>
    </div>

    <!-- Fan-spread hero cards (at the bottom) -->
    <div class="flex justify-center overflow-visible w-full md:mt-auto">
      <HeroCards members={featuredMembers} client:visible />
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.8s ease-out both;
  }
  .animate-slide-up {
    animation: slideUp 0.8s ease-out 0.1s both;
  }

  .hero-subtitle {
    animation: fadeIn 0.6s ease-out 0.05s both;
  }
  .hero-title {
    animation: slideUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
  }
  .hero-motto {
    animation: fadeIn 0.8s ease-out 0.5s both;
  }

  /* Mobile hero character animations */
  @keyframes heroEntrance {
    0% {
      opacity: 0;
      transform: translateY(60px) scale(0.9);
      filter: brightness(0.3) blur(6px);
    }
    50% {
      opacity: 0.8;
      filter: brightness(0.6) blur(2px);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: brightness(0.85) blur(0);
    }
  }

  @keyframes heroFloat {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  @keyframes heroBreath {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.02);
    }
  }

  .hero-char-mobile-wrapper {
    position: relative;
    display: flex;
    justify-content: center;
    animation: heroEntrance 1s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  .hero-char-mobile {
    position: relative;
    z-index: 1;
    width: 360px;
    height: auto;
    pointer-events: none;
    filter: brightness(0.85);
    mask-image: linear-gradient(to bottom, black 55%, transparent 95%);
    -webkit-mask-image: linear-gradient(to bottom, black 55%, transparent 95%);
    animation:
      heroFloat 4s ease-in-out 1.2s infinite,
      heroBreath 6s ease-in-out 1.2s infinite;
  }
</style>
