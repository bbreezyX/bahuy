---
import { CLAN } from "../data/clan";
import { members } from "../data/members";
---

<section
  id="stats"
  class="relative bg-transparent py-16 md:py-24 mt-8 md:mt-16"
>
  <!-- Subtle center divider -->
  <div class="mx-auto max-w-[120px] h-px bg-white/10 mb-14 md:mb-20"></div>

  <div class="mx-auto max-w-[1280px] px-6 md:px-10 lg:px-12">
    <div
      class="grid grid-cols-2 gap-y-14 gap-x-8 md:flex md:justify-between md:gap-0"
    >
      <!-- Members -->
      <div class="flex flex-col items-center text-center group">
        <span
          class="font-display text-5xl md:text-7xl text-white leading-none tracking-tighter"
          >{members.length}</span
        >
        <span
          class="font-condensed text-[11px] md:text-[13px] font-semibold uppercase tracking-[0.3em] text-white/40 mt-3"
          >Members</span
        >
      </div>

      <!-- Total Match -->
      <div class="flex flex-col items-center text-center group">
        <span
          class="font-display text-5xl md:text-7xl text-white leading-none tracking-tighter"
          >{CLAN.stats.totalMatch.toLocaleString()}+</span
        >
        <span
          class="font-condensed text-[11px] md:text-[13px] font-semibold uppercase tracking-[0.3em] text-white/40 mt-3"
          >Total Match</span
        >
      </div>

      <!-- Win Rate -->
      <div class="flex flex-col items-center text-center group">
        <span
          class="font-display text-5xl md:text-7xl text-white leading-none tracking-tighter"
          >{CLAN.stats.winRate}%</span
        >
        <span
          class="font-condensed text-[11px] md:text-[13px] font-semibold uppercase tracking-[0.3em] text-white/40 mt-3"
          >Win Rate</span
        >
      </div>

      <!-- Established -->
      <div class="flex flex-col items-center text-center group">
        <span
          class="font-display text-5xl md:text-7xl text-white leading-none tracking-tighter"
          >{CLAN.established}</span
        >
        <span
          class="font-condensed text-[11px] md:text-[13px] font-semibold uppercase tracking-[0.3em] text-white/40 mt-3"
          >Est.</span
        >
      </div>
    </div>
  </div>
</section>
