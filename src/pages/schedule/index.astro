---
import MainLayout from "../../layouts/MainLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import ScheduleView from "../../components/ScheduleView";
import { members } from "../../data/members";
---

<MainLayout>
  <Navbar currentPage="schedule" />
  <main>
    <section class="relative pt-32 md:pt-40 pb-8 md:pb-12">
      <div class="mx-auto max-w-[1280px] px-4 md:px-6 lg:px-8">
        <p
          class="font-condensed text-sm sm:text-base uppercase tracking-[0.3em] text-primary/60 mb-3 font-semibold text-center sm:text-left"
        >
          Main Bareng
        </p>
        <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-6">
          <h1
            class="font-display text-5xl md:text-6xl lg:text-7xl tracking-wide text-white leading-none"
          >
            SCHEDULE
          </h1>
          <div class="hidden sm:flex items-center gap-3 flex-1">
            <div class="h-px flex-1 bg-white/10"></div>
            <span
              class="font-condensed text-sm uppercase tracking-[0.2em] text-white/30"
            >
              Jadwal Main
            </span>
          </div>
          <p
            class="sm:hidden font-condensed text-sm uppercase tracking-[0.2em] text-white/30"
          >
            Jadwal Main
          </p>
        </div>
      </div>
    </section>

    <ScheduleView members={members} client:load />

    <!-- Admin link -->
    <div class="mx-auto max-w-[1280px] px-4 md:px-6 lg:px-8 pb-20">
      <div class="flex items-center justify-center">
        <a
          href="/schedule/admin"
          class="group inline-flex items-center gap-2.5 px-5 py-2.5 rounded-full border border-white/[0.08] hover:border-white/20 transition-colors"
        >
          <svg
            class="w-4 h-4 text-white/25 group-hover:text-primary/60 transition-colors"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
          <span
            class="font-condensed text-xs uppercase tracking-[0.15em] text-white/25 group-hover:text-white/50 transition-colors"
          >
            Kelola Jadwal
          </span>
          <span
            class="font-condensed text-[10px] uppercase tracking-[0.1em] text-white/15 border border-white/[0.06] rounded px-1.5 py-0.5"
          >
            Admin
          </span>
        </a>
      </div>
    </div>
  </main>
  <Footer />
</MainLayout>
