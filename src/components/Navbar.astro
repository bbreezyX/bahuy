---
import { CLAN } from "../data/clan";

interface Props {
  currentPage?: string;
}

const { currentPage = "home" } = Astro.props;
const isHome = currentPage === "home";
---

<nav class="fixed top-0 left-0 right-0 z-50 h-24 bg-transparent">
  <div
    class="mx-auto flex h-full max-w-[1400px] items-center justify-between px-6 md:px-10 lg:px-12 relative"
  >
    <!-- Left: Desktop Nav Links -->
    <div class="flex-1 flex items-center justify-start">
      <div class="hidden md:flex items-center gap-10">
        <a
          href={isHome ? "#hero" : "/"}
          class:list={["font-condensed text-sm font-semibold uppercase tracking-[0.15em] transition-colors", currentPage === "home" ? "text-primary" : "text-white hover:text-primary"]}
          >Home</a
        >
        <a
          href={isHome ? "#members" : "/#members"}
          class="font-condensed text-sm font-semibold uppercase tracking-[0.15em] text-white hover:text-primary transition-colors"
          >Members</a
        >
        <a
          href={isHome ? "#stats" : "/#stats"}
          class="font-condensed text-sm font-semibold uppercase tracking-[0.15em] text-white hover:text-primary transition-colors"
          >Stats</a
        >
        <a
          href="/schedule"
          class:list={["font-condensed text-sm font-semibold uppercase tracking-[0.15em] transition-colors", currentPage === "schedule" ? "text-primary" : "text-white hover:text-primary"]}
          >Schedule</a
        >
      </div>
      <!-- Mobile menu button on left for small screens where links are hidden -->
      <button
        id="mobile-menu-btn"
        class="md:hidden flex h-8 w-8 items-center justify-center rounded-lg text-white/70 hover:text-primary transition-all"
        aria-label="Open menu"
      >
        <svg
          class="h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><line x1="4" y1="6" x2="20" y2="6"></line><line
            x1="4"
            y1="12"
            x2="20"
            y2="12"></line><line x1="4" y1="18" x2="20" y2="18"></line></svg
        >
      </button>
    </div>

    <!-- Center: Logo -->
    <div
      class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 flex justify-center pointer-events-none"
    >
      <a href="/" class="flex items-center group pointer-events-auto">
        <div class="flex h-10 w-10 items-center justify-center transition-all">
          <svg
            class="h-7 w-7 text-primary group-hover:scale-110 transition-transform"
            viewBox="0 0 32 32"
            fill="none"
          >
            <circle cx="16" cy="16" r="7" stroke="currentColor" stroke-width="1.5"></circle>
            <circle cx="16" cy="16" r="2.5" fill="currentColor"></circle>
            <line x1="16" y1="1" x2="16" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></line>
            <line x1="16" y1="25" x2="16" y2="31" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></line>
            <line x1="1" y1="16" x2="7" y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></line>
            <line x1="25" y1="16" x2="31" y2="16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></line>
            <line x1="5.4" y1="5.4" x2="9.2" y2="9.2" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.4"></line>
            <line x1="22.8" y1="22.8" x2="26.6" y2="26.6" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.4"></line>
            <line x1="26.6" y1="5.4" x2="22.8" y2="9.2" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.4"></line>
            <line x1="9.2" y1="22.8" x2="5.4" y2="26.6" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.4"></line>
          </svg>
        </div>
      </a>
    </div>

    <!-- Right: Social icons -->
    <div class="flex-1 flex items-center justify-end gap-3">
      <div class="hidden sm:flex items-center gap-3">
        <a
          href={CLAN.socials.discord}
          target="_blank"
          rel="noopener"
          class="flex h-10 w-10 items-center justify-center rounded-lg text-white/70 hover:text-primary transition-all"
          aria-label="Discord"
        >
          <svg
            class="h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
            ></path></svg
          >
        </a>
        <a
          href={CLAN.socials.instagram}
          target="_blank"
          rel="noopener"
          class="flex h-10 w-10 items-center justify-center rounded-lg text-white/70 hover:text-primary transition-all"
          aria-label="Instagram"
        >
          <svg
            class="h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path
              d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line
              x1="17.5"
              y1="6.5"
              x2="17.51"
              y2="6.5"></line></svg
          >
        </a>
      </div>
    </div>
  </div>
</nav>

<!-- Floating Mobile Menu -->
<div id="mobile-menu" class="fixed inset-0 z-[100] pointer-events-none md:hidden" aria-hidden="true">
  <div
    id="mobile-menu-backdrop"
    class="absolute inset-0 bg-black/0 backdrop-blur-0 transition-all duration-500 ease-out"
  ></div>

  <div class="absolute inset-x-0 top-20 px-5">
    <div
      class="mobile-card opacity-0 translate-y-4 scale-[0.98] pointer-events-none rounded-2xl border border-border/50 bg-card/85 backdrop-blur-xl shadow-[0_8px_40px_rgba(0,0,0,0.45)] transition-all duration-400 ease-[cubic-bezier(0.16,1,0.3,1)]"
    >
      <nav class="flex flex-col p-2" aria-label="Mobile navigation">
        <a
          href={isHome ? "#hero" : "/"}
          class="mobile-nav-link group flex items-center gap-3 rounded-xl px-4 py-3.5 transition-all duration-150 hover:bg-white/[0.05] active:bg-white/[0.08]"
        >
          <svg class="h-[18px] w-[18px] shrink-0 text-muted-foreground transition-colors group-hover:text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
          <span class:list={["font-condensed text-[15px] font-semibold uppercase tracking-[0.12em] group-hover:text-white", currentPage === "home" ? "text-primary" : "text-white/90"]}>Home</span>
        </a>
        <a
          href={isHome ? "#members" : "/#members"}
          class="mobile-nav-link group flex items-center gap-3 rounded-xl px-4 py-3.5 transition-all duration-150 hover:bg-white/[0.05] active:bg-white/[0.08]"
        >
          <svg class="h-[18px] w-[18px] shrink-0 text-muted-foreground transition-colors group-hover:text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          <span class="font-condensed text-[15px] font-semibold uppercase tracking-[0.12em] text-white/90 group-hover:text-white">Members</span>
        </a>
        <a
          href={isHome ? "#stats" : "/#stats"}
          class="mobile-nav-link group flex items-center gap-3 rounded-xl px-4 py-3.5 transition-all duration-150 hover:bg-white/[0.05] active:bg-white/[0.08]"
        >
          <svg class="h-[18px] w-[18px] shrink-0 text-muted-foreground transition-colors group-hover:text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
          <span class="font-condensed text-[15px] font-semibold uppercase tracking-[0.12em] text-white/90 group-hover:text-white">Stats</span>
        </a>
        <a
          href="/schedule"
          class="mobile-nav-link group flex items-center gap-3 rounded-xl px-4 py-3.5 transition-all duration-150 hover:bg-white/[0.05] active:bg-white/[0.08]"
        >
          <svg class="h-[18px] w-[18px] shrink-0 text-muted-foreground transition-colors group-hover:text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          <span class:list={["font-condensed text-[15px] font-semibold uppercase tracking-[0.12em] group-hover:text-white", currentPage === "schedule" ? "text-primary" : "text-white/90"]}>Schedule</span>
        </a>
      </nav>

      <div class="h-px mx-4 bg-border/40"></div>

      <div class="flex items-center justify-center gap-3 px-4 py-3">
        <a
          href={CLAN.socials.discord}
          target="_blank"
          rel="noopener"
          class="flex h-9 w-9 items-center justify-center rounded-lg text-muted-foreground hover:text-[#5865F2] transition-colors duration-150"
          aria-label="Discord"
        >
          <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"></path></svg>
        </a>
        <a
          href={CLAN.socials.instagram}
          target="_blank"
          rel="noopener"
          class="flex h-9 w-9 items-center justify-center rounded-lg text-muted-foreground hover:text-[#E4405F] transition-colors duration-150"
          aria-label="Instagram"
        >
          <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"></path></svg>
        </a>
        <a
          href={CLAN.socials.youtube}
          target="_blank"
          rel="noopener"
          class="flex h-9 w-9 items-center justify-center rounded-lg text-muted-foreground hover:text-[#FF0000] transition-colors duration-150"
          aria-label="YouTube"
        >
          <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"></path></svg>
        </a>
      </div>

      <div class="h-px mx-4 bg-border/40"></div>

      <div class="px-4 py-3">
        <button
          id="mobile-menu-close"
          class="flex w-full items-center justify-center gap-2 rounded-xl py-2.5 text-muted-foreground hover:text-white hover:bg-white/[0.05] active:bg-white/[0.08] transition-all duration-150"
          aria-label="Close menu"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          <span class="font-condensed text-xs font-semibold uppercase tracking-[0.15em]">Close</span>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const closeBtn = document.getElementById("mobile-menu-close");
  const backdrop = document.getElementById("mobile-menu-backdrop");
  const card = document.querySelector(".mobile-card");
  const links = document.querySelectorAll(".mobile-nav-link");

  let isOpen = false;

  function openMenu() {
    if (isOpen) return;
    isOpen = true;
    menu?.setAttribute("aria-hidden", "false");
    menu?.classList.remove("pointer-events-none");

    if (backdrop) {
      backdrop.classList.remove("bg-black/0", "backdrop-blur-0");
      backdrop.classList.add("bg-black/50", "backdrop-blur-sm");
      backdrop.style.pointerEvents = "auto";
    }

    card?.classList.remove("opacity-0", "translate-y-4", "scale-[0.98]", "pointer-events-none");
    card?.classList.add("opacity-100", "translate-y-0", "scale-100", "pointer-events-auto");
  }

  function closeMenu() {
    if (!isOpen) return;
    isOpen = false;

    if (backdrop) {
      backdrop.classList.remove("bg-black/50", "backdrop-blur-sm");
      backdrop.classList.add("bg-black/0", "backdrop-blur-0");
      backdrop.style.pointerEvents = "none";
    }

    card?.classList.add("opacity-0", "translate-y-4", "scale-[0.98]", "pointer-events-none");
    card?.classList.remove("opacity-100", "translate-y-0", "scale-100", "pointer-events-auto");

    setTimeout(() => {
      menu?.setAttribute("aria-hidden", "true");
      menu?.classList.add("pointer-events-none");
    }, 450);
  }

  btn?.addEventListener("click", openMenu);
  closeBtn?.addEventListener("click", closeMenu);
  backdrop?.addEventListener("click", closeMenu);
  links.forEach((link) => link.addEventListener("click", closeMenu));

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && isOpen) closeMenu();
  });
</script>
