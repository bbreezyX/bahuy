---
import "../styles/globals.css";
import { CLAN } from "../data/clan";
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={`${CLAN.name} — ${CLAN.subtitle}. ${CLAN.motto}`}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Black+Ops+One&family=Rajdhani:wght@300;400;500;600;700&family=Teko:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{CLAN.name} | {CLAN.subtitle}</title>
  </head>
  <body class="min-h-screen overflow-x-hidden">
    <!-- Corridor grid background -->
    <div class="corridor-grid" aria-hidden="true">
      <div class="corridor-grid__left"></div>
      <div class="corridor-grid__right"></div>
    </div>

    <!-- Decorative character images -->
    <div class="char-deco char-deco--left" aria-hidden="true">
      <img src="/cha01.png" alt="" draggable="false" />
    </div>
    <div class="char-deco char-deco--right" aria-hidden="true">
      <img src="/cha02.png" alt="" draggable="false" />
    </div>

    <div class="relative z-10 flex flex-col min-h-screen">
      <slot />
    </div>
  </body>
</html>

<style>
  .corridor-grid {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    perspective: 600px;
    overflow: hidden;
  }

  .corridor-grid__left,
  .corridor-grid__right {
    position: absolute;
    top: -20%;
    width: 42%;
    height: 140%;
    background-image:
      linear-gradient(to right, rgba(255, 255, 255, 0.06) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .corridor-grid__left {
    left: 0;
    transform-origin: left center;
    transform: rotateY(35deg);
    mask-image: linear-gradient(to right, black 10%, transparent 70%);
    -webkit-mask-image: linear-gradient(to right, black 10%, transparent 70%);
  }

  .corridor-grid__right {
    right: 0;
    transform-origin: right center;
    transform: rotateY(-35deg);
    mask-image: linear-gradient(to left, black 10%, transparent 70%);
    -webkit-mask-image: linear-gradient(to left, black 10%, transparent 70%);
  }

  /* ── Decorative character images ── */
  .char-deco {
    position: fixed;
    bottom: 0;
    z-index: 5;
    pointer-events: none;
    display: none;
  }

  .char-deco img {
    display: block;
    height: 80vh;
    width: auto;
    object-fit: contain;
    position: relative;
    z-index: 1;
    filter: brightness(0.55);
  }

  .char-deco--left {
    left: -6%;
  }

  .char-deco--left img {
    mask-image: linear-gradient(to right, black 65%, transparent 95%);
    -webkit-mask-image: linear-gradient(to right, black 65%, transparent 95%);
  }

  .char-deco--right {
    right: 0;
  }

  .char-deco--right img {
    mask-image: linear-gradient(to left, black 65%, transparent 95%);
    -webkit-mask-image: linear-gradient(to left, black 65%, transparent 95%);
  }

  @media (min-width: 1024px) {
    .char-deco {
      display: block;
    }
  }
</style>
